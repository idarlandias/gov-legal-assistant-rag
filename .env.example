# Copie para .env e preencha. NUNCA commitar .env.
# Escolha 1 provider (default: Gemini Free Tier — ver CURRICULUM.md §Setup de API e Custo)

# Opção A — Gemini Free Tier (default)
# GEMINI_API_KEY=AIza_substitua_aqui

# Opção B — OpenAI ($5 free credit)
# OPENAI_API_KEY=sk-substitua

# Opção C — Anthropic ($5 free credit, expira 14d após claim)
# ANTHROPIC_API_KEY=sk-ant-substitua

# Opção D — DeepSeek
# DEEPSEEK_API_KEY=sk-substitua

# Opção E — Groq
GROQ_API_KEY=gsk-substitua

# Provedor padrão: gemini | openai | deepseek | groq
LLM_PROVIDER=groq

# Modelos (descomente conforme provider)
# Se LLM_PROVIDER=gemini:
# CHEAP_MODEL=gemini-2.5-flash-lite
# PREMIUM_MODEL=gemini-2.5-pro

# Se LLM_PROVIDER=groq:
CHEAP_MODEL=llama-3.3-70b-versatile
PREMIUM_MODEL=deepseek-r1-distill-llama-70b

# Para embeddings locais (default do Chroma), deixe em branco. Se quiser Gemini: gemini-embedding-001
EMBED_MODEL=local

# Opcional — observabilidade (descomente se for usar Langfuse)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
